{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedOnStartup": false
  },
  "Seed": {
    "Admin": {
      "Password": ""
    }
  },
  "Storage": {
    "Provider": "Local",
    "RootPath": "storage/assets",
    "LocalRootPath": "storage/assets",
    "PublicBaseUrl": "/assets",
    "MaxFileSizeBytes": 10485760,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp",
      "image/gif",
      "application/pdf"
    ],
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerName": "",
      "PublicBaseUrl": ""
    },
    "S3": {
      "BucketName": "",
      "Region": "",
      "PublicBaseUrl": ""
    }
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "localhost:6379",
    "FeaturedPostsCacheMinutes": 5
  },
  "RateLimiting": {
    "FailClosedWhenUnavailable": false,
    "Login": {
      "MaxFailedAttempts": 5,
      "WindowMinutes": 10
    }
  },
  "Email": {
    "Smtp": {
      "Enabled": false,
      "Host": "localhost",
      "Port": 1025,
      "UseSsl": false,
      "Username": "",
      "Password": "",
      "FromEmail": "no-reply@contenthub.local",
      "FromName": "ContentHub"
    }
  },
  "BackgroundJobs": {
    "Enabled": true,
    "RequireDistributedLock": false,
    "ScheduledPostPublisher": {
      "Enabled": true,
      "IntervalSeconds": 60,
      "BatchSize": 25
    },
    "NotificationDelivery": {
      "Enabled": true,
      "IntervalSeconds": 30,
      "BatchSize": 50
    },
    "ExpiredTokenCleanup": {
      "Enabled": true,
      "IntervalMinutes": 60,
      "RetentionDays": 7,
      "BatchSize": 100
    }
  }
}
