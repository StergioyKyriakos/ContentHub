{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=contenthub;Username=contenthub;Password=contenthub"
  },
  
  "Jwt": {
    "Issuer": "ContentHub",
    "Audience": "ContentHub",
    "Secret": "THIS_IS_A_DEVELOPMENT_SECRET_KEY_CHANGE_IT_LATER_123456789",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Storage": {
    "Provider": "Local",
    "LocalRootPath": "storage/assets",
    "PublicBaseUrl": "/assets",
    "MaxFileSizeBytes": 10485760,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp",
      "image/gif",
      "application/pdf"
    ]
  }
}
